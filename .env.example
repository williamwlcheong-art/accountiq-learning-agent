# Copy this file to .env and fill in your values
# Get your key from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-YOUR_KEY_HERE

# Optional: override the Claude model
# CLAUDE_MODEL=claude-opus-4-5

# Optional locally, required before exposing mutation/admin endpoints.
# Send requests with the X-Admin-Token header when this is set.
# APP_ADMIN_TOKEN=change-me

# Internal service token for the Next.js app to queue extraction jobs.
# EXTRACTOR_SERVICE_TOKEN=change-me-too

# Required when the Python extractor downloads customer uploads from Supabase Storage.
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Comma-separated browser origins allowed to call the API.
# APP_CORS_ORIGINS=http://localhost:3000,http://localhost:8765
