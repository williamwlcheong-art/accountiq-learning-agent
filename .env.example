# Copy this file to .env and fill in your values
# Get your key from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-YOUR_KEY_HERE

# Optional: override the Claude model
# CLAUDE_MODEL=claude-opus-4-5

# JWT signing key. Generate with: openssl rand -hex 32
SECRET_KEY=replace-me-with-output-of-openssl-rand-hex-32

# Local/browser E2E mode. Uses deterministic fixture extraction/report output
# and can point the backend at an isolated SQLite DB.
ACCOUNTIQ_E2E_MODE=false
ACCOUNTIQ_DB_PATH=

# Set to your email address to automatically grant admin access on first registration
# OWNER_EMAIL=your@email.com

# Phase 5: Email delivery (smtplib — swap to Resend in Phase 6)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
FROM_EMAIL=
APP_BASE_URL=http://localhost:8765
