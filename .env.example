# Copy this file to .env and fill in your values
# Get your key from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-YOUR_KEY_HERE

# Optional: override the Claude model
# CLAUDE_MODEL=claude-opus-4-5

# JWT signing key. Generate with: openssl rand -hex 32
SECRET_KEY=replace-me-with-output-of-openssl-rand-hex-32

# Set to your email address to automatically grant admin access on first registration
# OWNER_EMAIL=your@email.com

# Phase 5: Email delivery (smtplib — swap to Resend in Phase 6)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
FROM_EMAIL=
APP_BASE_URL=http://localhost:3000

# E2E test mode only
# ACCOUNTIQ_DB_PATH=data/accountiq_e2e.db
ACCOUNTIQ_E2E_MODE=false

# Next.js frontend
FASTAPI_ORIGIN=http://127.0.0.1:8765
NEXT_PUBLIC_API_BASE=/api/backend

# Legacy vanilla frontend fallback. The migrated app lives in web/.
ACCOUNTIQ_SERVE_LEGACY_FRONTEND=false
