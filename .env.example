# Copy this file to .env and fill in your values
# Get your key from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-YOUR_KEY_HERE

# Optional: override the Claude model
# CLAUDE_MODEL=claude-opus-4-5

# JWT signing key. Generate with: openssl rand -hex 32
SECRET_KEY=replace-me-with-output-of-openssl-rand-hex-32

# Set to your email address to automatically grant admin access on first registration
# OWNER_EMAIL=your@email.com
